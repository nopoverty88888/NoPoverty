# Supabase — copy this file to `.env.local` and fill in real values.
# Get these from your Supabase project: Project Settings → API.

# Public (safe to expose to the browser — used by the client SDK)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — NEVER expose to the browser or commit. Bypasses Row-Level
# Security; used only by server routes and scripts (e.g. scripts/seed-admin.ts).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
